---
import {
	getNavigation,
	hrefForSlug,
	slugFromPathname,
} from "@/utils/navigation";
import { ArrowLeft, ArrowRight } from "svelte-radix";

const navigation = getNavigation();
const items = navigation.sections
	.flatMap((section) =>
		section.items.flatMap((item) => [item, ...item.subarticles]),
	)
	.filter((item) => !item.hidePrevNext);
const currentSlug = slugFromPathname(Astro.url.pathname);
const currentIndex = items.findIndex((item) => item.slug === currentSlug);
const prevPage = currentIndex > 0 ? items[currentIndex - 1] : null;
const nextPage =
	currentIndex >= 0 ? (items[currentIndex + 1] ?? null) : null;
---

{
	(prevPage || nextPage) && (
		<nav class="border-t border-ui-border mt-16 pt-8">
			<div class="flex justify-between items-center gap-4">
				{prevPage ? (
					<a
						href={hrefForSlug(prevPage.slug)}
						class="flex-1 group flex flex-col gap-1 p-4 rounded-lg border border-ui-border hover:border-ui-border-strong hover:bg-ui-surface-subtle transition-colors"
					>
						<span class="text-xs font-medium text-ui-text-muted uppercase tracking-wider">
							Previous
						</span>
						<span class="text-sm font-medium text-ui-text-secondary group-hover:text-ui-text-primary transition-colors flex items-center gap-1">
							<ArrowLeft class="size-4" />
							{prevPage.title}
						</span>
					</a>
				) : (
					<div class="flex-1" />
				)}

				{nextPage ? (
					<a
						href={hrefForSlug(nextPage.slug)}
						class="flex-1 group flex flex-col gap-1 p-4 rounded-lg border border-ui-border hover:border-ui-border-strong hover:bg-ui-surface-subtle transition-colors text-right"
					>
						<span class="text-xs font-medium text-ui-text-muted uppercase tracking-wider">
							Next
						</span>
						<span class="text-sm font-medium text-ui-text-secondary group-hover:text-ui-text-primary transition-colors flex items-center gap-1 justify-end">
							{nextPage.title}
							<ArrowRight class="size-4" />
						</span>
					</a>
				) : (
					<div class="flex-1" />
				)}
			</div>
		</nav>
	)
}
