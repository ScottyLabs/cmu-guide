---
import { HamburgerMenu } from "svelte-radix";

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<aside
	class="w-full lg:w-64 lg:fixed lg:right-0 lg:top-28 h-auto text-sm lg:px-4"
	aria-label="On this page"
	data-toc
>
	<div class="bg-transparent">
		<div class="flex items-center gap-2 mb-3">
			<HamburgerMenu class="w-4 h-4 text-ui-text-muted" />
			<p class="text-ui-text-muted">On this page</p>
		</div>

		<ul class="pl-4">
			{
				filteredHeadings.map((h) => (
					<li>
						<a
							href={`#${h.slug}`}
							data-toc-link
							data-slug={h.slug}
							class={`block text-ui-text-muted hover:text-ui-text-primary transition-colors border-l border-ui-border -ml-4 py-1 ${h.depth === 3 ? "pl-8" : "pl-4"}`}
						>
							{h.text}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</aside>

<script>
	const activeLinkClasses = [
		"!text-ui-text-primary",
		"font-medium",
		"!border-l-ui-text-primary",
	];
	let cleanupTOC: (() => void) | null = null;

	function initTOC() {
		cleanupTOC?.();

		const tocElements = document.querySelectorAll("[data-toc]");
		const headings = Array.from(document.querySelectorAll("h2[id], h3[id]"));
		const dormAnchors = Array.from(
			document.querySelectorAll<HTMLElement>("[data-dorm-anchor]"),
		);
		const dorms = dormAnchors.length ? (window as any).__dorms__ : undefined;
		const cleanups: Array<() => void> = [];

		tocElements.forEach((tocElement) => {
			const tocList = tocElement.querySelector("ul");
			if (!tocList) return;

			tocList.querySelectorAll("[data-dorm-link]").forEach((link) =>
				link.closest("li")?.remove(),
			);

			if (dorms?.length) {
				dorms.forEach((dorm: any) => {
					const id = dorm.name.replace(/\s+/g, "-");
					const li = document.createElement("li");
					const link = document.createElement("a");
					link.href = `#${id}`;
					link.setAttribute("data-toc-link", "");
					link.setAttribute("data-slug", id);
					link.setAttribute("data-dorm-link", "");
					link.textContent = dorm.name;
					link.className =
						"block text-ui-text-muted hover:text-ui-text-primary transition-colors border-l border-ui-border -ml-4 py-1 pl-8";
					li.appendChild(link);
					tocList.appendChild(li);
				});
			}

			const links = Array.from(
				tocElement.querySelectorAll<HTMLElement>("[data-toc-link]"),
			);
			const staticLinks = links.filter(
				(link) => !link.hasAttribute("data-dorm-link"),
			);
			if (!staticLinks.length) return;

			let userClicked = false;
			let clickTimeout: ReturnType<typeof setTimeout> | null = null;
			const visibleHeadingIds = new Set<string>();
			const visibleDormIds = new Set<string>();
			let activeStaticSlug = staticLinks[0].getAttribute("data-slug")!;

			function renderActiveLink() {
				links.forEach((link) => {
					link.classList.remove(...activeLinkClasses);
				});

				const activeDormSlug = dormAnchors.reduce<string | undefined>(
					(lastVisibleSlug, dormAnchor) =>
						visibleDormIds.has(dormAnchor.id)
							? dormAnchor.id
							: lastVisibleSlug,
					undefined,
				);
				const activeSlug = activeDormSlug ?? activeStaticSlug;

				const tocLink = tocElement.querySelector(
					`[data-toc-link][data-slug="${activeSlug}"]`,
				);
				tocLink?.classList.add(...activeLinkClasses);
			}

			function updateActiveStaticLink() {
				const lastVisibleId = headings.reduce<string | undefined>(
					(lastVisibleSlug, heading) =>
						visibleHeadingIds.has(heading.id)
							? heading.id
							: lastVisibleSlug,
					undefined,
				);
				if (lastVisibleId) {
					activeStaticSlug = lastVisibleId;
				}
			}

			renderActiveLink();

			// Handle clicks on TOC links
			staticLinks.forEach((link) => {
				const handleClick = () => {
					const slug = link.getAttribute("data-slug");
					if (slug) {
						userClicked = true;
						activeStaticSlug = slug;
						renderActiveLink();

						if (clickTimeout) {
							clearTimeout(clickTimeout);
						}

						// Re-enable intersection observer after scroll settles
						clickTimeout = setTimeout(() => {
							userClicked = false;
							updateActiveStaticLink();
							renderActiveLink();
						}, 1000);
					}
				};

				link.addEventListener("click", handleClick);
				cleanups.push(() => link.removeEventListener("click", handleClick));
			});

			const headingObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.getAttribute("id");
						if (!id) return;

						if (entry.isIntersecting) {
							visibleHeadingIds.add(id);
						} else {
							visibleHeadingIds.delete(id);
						}
					});

					if (!userClicked) {
						updateActiveStaticLink();
						renderActiveLink();
					}
				},
				{
					rootMargin: "-100px 0px -66%",
					threshold: 1,
				},
			);

			headings.forEach((heading) => headingObserver.observe(heading));
			cleanups.push(() => headingObserver.disconnect());
			cleanups.push(() => {
				if (clickTimeout) clearTimeout(clickTimeout);
			});

			const dormObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.getAttribute("id");
						if (!id) return;

						if (entry.isIntersecting) {
							visibleDormIds.add(id);
						} else {
							visibleDormIds.delete(id);
						}
					});

					if (!userClicked) renderActiveLink();
				},
				{
					rootMargin: "-100px 0px -66%",
					threshold: 0,
				},
			);

			dormAnchors.forEach((dormAnchor) => dormObserver.observe(dormAnchor));
			cleanups.push(() => dormObserver.disconnect());
		});

		cleanupTOC = () => {
			cleanups.forEach((cleanup) => cleanup());
		};
	}

	initTOC();

	window.addEventListener("dorms-ready", initTOC);
	document.addEventListener("astro:after-swap", initTOC);
</script>
