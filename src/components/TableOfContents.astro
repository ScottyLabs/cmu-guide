---
import { HamburgerMenu } from "svelte-radix";

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<aside
	class="w-full lg:w-64 lg:fixed lg:right-0 lg:top-28 h-auto text-sm lg:px-4"
	aria-label="On this page"
	data-toc
>
	<div class="bg-transparent">
		<div class="flex items-center gap-2 mb-3">
			<HamburgerMenu class="w-4 h-4 text-ui-text-muted" />
			<p class="text-ui-text-muted">On this page</p>
		</div>

		<ul class="pl-4">
			{
				filteredHeadings.map((h) => (
					<li>
						<a
							href={`#${h.slug}`}
							data-toc-link
							data-slug={h.slug}
							class={`block text-ui-text-muted hover:text-ui-text-primary transition-colors border-l border-ui-border -ml-4 py-1 ${h.depth === 3 ? "pl-8" : "pl-4"}`}
						>
							{h.text}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</aside>

<script>
	function initTOC() {
		const tocElements = document.querySelectorAll("[data-toc]");
		const headings = Array.from(document.querySelectorAll("h2[id], h3[id]"));

		tocElements.forEach((tocElement) => {
			const links = tocElement.querySelectorAll(
				"[data-toc-link]:not([data-dorm-link])",
			);
			if (!links.length) return;

			let userClicked = false;
			let clickTimeout: ReturnType<typeof setTimeout> | null = null;
			const visibleHeadingIds = new Set<string>();

			function clearActiveLinks() {
				links.forEach((link) => {
					link.classList.remove(
						"!text-ui-text-primary",
						"font-medium",
						"!border-l-ui-text-primary",
					);
				});
			}

			function setActiveLink(slug: string) {
				tocElement.setAttribute("data-active-static-slug", slug);
				clearActiveLinks();

				const tocLink = tocElement.querySelector(
					`[data-toc-link][data-slug="${slug}"]`,
				);

				if (tocLink && !tocElement.hasAttribute("data-dorm-active")) {
					tocLink.classList.add(
						"!text-ui-text-primary",
						"font-medium",
						"!border-l-ui-text-primary",
					);
				}
			}

			function reconcileActiveLink() {
				const lastVisibleId = headings.reduce<string | undefined>(
					(lastVisibleSlug, heading) =>
						visibleHeadingIds.has(heading.id)
							? heading.id
							: lastVisibleSlug,
					undefined,
				);
				if (lastVisibleId) setActiveLink(lastVisibleId);
			}

			setActiveLink(links[0].getAttribute("data-slug")!);

			links.forEach((link) => {
				link.addEventListener("click", () => {
					const slug = link.getAttribute("data-slug");
					if (!slug) return;

					userClicked = true;
					setActiveLink(slug);
					if (clickTimeout) clearTimeout(clickTimeout);
					clickTimeout = setTimeout(() => {
						userClicked = false;
						reconcileActiveLink();
					}, 1000);
				});
			});

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.getAttribute("id");
						if (!id) return;

						if (entry.isIntersecting) visibleHeadingIds.add(id);
						else visibleHeadingIds.delete(id);
					});

					if (!userClicked) reconcileActiveLink();
				},
				{ rootMargin: "-100px 0px -66%", threshold: 1 },
			);

			headings.forEach((heading) => observer.observe(heading));
		});
	}

	function initDormTOC() {
		const dorms = (window as any).__dorms__;
		const dormAnchors = Array.from(
			document.querySelectorAll<HTMLElement>("[data-dorm-anchor]"),
		);
		if (!dorms?.length || !dormAnchors.length) return;

		document.querySelectorAll("[data-toc] ul").forEach((toc: Element) => {
			toc
				.querySelectorAll("[data-dorm-link]")
				.forEach((el) => el.closest("li")?.remove());

			dorms.forEach((dorm: any) => {
				const id = dorm.name.replace(/\s+/g, "-");
				const li = document.createElement("li");
				const link = document.createElement("a");
				link.href = `#${id}`;
				link.setAttribute("data-toc-link", "");
				link.setAttribute("data-slug", id);
				link.setAttribute("data-dorm-link", "");
				link.textContent = dorm.name;
				link.className =
					"block text-ui-text-muted hover:text-ui-text-primary transition-colors border-l border-ui-border -ml-4 py-1 pl-8";
				li.appendChild(link);
				toc.appendChild(li);
			});
		});

		requestAnimationFrame(() => {
			document.querySelectorAll("[data-toc]").forEach((tocElement) => {
				const visibleDormIds = new Set<string>();

				function restoreStaticLink() {
					const slug = tocElement.getAttribute("data-active-static-slug");
					const staticLink = slug
						? tocElement.querySelector(
								`[data-toc-link]:not([data-dorm-link])[data-slug="${slug}"]`,
							)
						: null;
					staticLink?.classList.add(
						"!text-ui-text-primary",
						"font-medium",
						"!border-l-ui-text-primary",
					);
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							const id = entry.target.getAttribute("id");
							if (!id) return;
							if (entry.isIntersecting) visibleDormIds.add(id);
							else visibleDormIds.delete(id);
						});

						const activeDormId = dormAnchors.reduce<string | undefined>(
							(lastVisibleId, dormAnchor) =>
								visibleDormIds.has(dormAnchor.id)
									? dormAnchor.id
									: lastVisibleId,
							undefined,
						);
						tocElement
							.querySelectorAll("[data-dorm-link].font-medium")
							.forEach((link) =>
								link.classList.remove(
									"!text-ui-text-primary",
									"font-medium",
									"!border-l-ui-text-primary",
								),
							);

						if (activeDormId) {
							tocElement.setAttribute("data-dorm-active", "");
							tocElement
								.querySelector("[data-toc-link]:not([data-dorm-link]).font-medium")
								?.classList.remove(
									"!text-ui-text-primary",
									"font-medium",
									"!border-l-ui-text-primary",
								);
							tocElement
								.querySelector(`[data-toc-link][data-slug="${activeDormId}"]`)
								?.classList.add(
									"!text-ui-text-primary",
									"font-medium",
									"!border-l-ui-text-primary",
								);
						} else {
							tocElement.removeAttribute("data-dorm-active");
							restoreStaticLink();
						}
					},
					{ rootMargin: "-100px 0px -66%", threshold: 0 },
				);

				dormAnchors.forEach((anchor) => observer.observe(anchor));
			});
		});
	}

	initTOC();
	initDormTOC();

	window.addEventListener("dorms-ready", initDormTOC);
	document.addEventListener("astro:after-swap", initTOC);
	document.addEventListener("astro:after-swap", initDormTOC);
</script>
