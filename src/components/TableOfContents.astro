---
import { HamburgerMenu } from "svelte-radix";

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<aside
	class="w-full lg:w-64 lg:fixed lg:right-0 lg:top-28 h-auto text-sm lg:px-4"
	aria-label="On this page"
	data-toc
>
	<div class="bg-transparent">
		<div class="flex items-center gap-2 mb-3">
			<HamburgerMenu class="w-4 h-4 text-ui-text-muted" />
			<p class="text-ui-text-muted">On this page</p>
		</div>

		<ul class="pl-4">
			{
				filteredHeadings.map((h) => (
					<li>
						<a
							href={`#${h.slug}`}
							data-toc-link
							data-slug={h.slug}
							class={`block text-ui-text-muted hover:text-ui-text-primary transition-colors border-l border-ui-border -ml-4 py-1 ${h.depth === 3 ? "pl-8" : "pl-4"}`}
						>
							{h.text}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</aside>

<script>
	let cleanupTOC: (() => void) | null = null;

	function initTOC() {
		cleanupTOC?.();

		const tocElements = document.querySelectorAll("[data-toc]");
		const headings = Array.from(document.querySelectorAll("h2[id], h3[id]"));
		if (!tocElements.length || !headings.length) return;

		let animationFrame: number | null = null;

		function setActiveLink(tocElement: Element, slug?: string) {
			const links = tocElement.querySelectorAll(
				"[data-toc-link]:not([data-dorm-link])",
			);

			links.forEach((link) => {
				link.classList.remove(
					"!text-ui-text-primary",
					"font-medium",
					"!border-l-ui-text-primary",
				);
			});

			const tocLink = slug
				? Array.from(links).find(
					(link) => link.getAttribute("data-slug") === slug,
				)
				: undefined;

			tocLink?.classList.add(
				"!text-ui-text-primary",
				"font-medium",
				"!border-l-ui-text-primary",
			);
		}

		function scheduleActiveLinkUpdate() {
			if (animationFrame !== null) return;

			animationFrame = requestAnimationFrame(() => {
				animationFrame = null;
				updateActiveLinks();
			});
		}

		function updateActiveLinks() {
			const readingLine = window.matchMedia("(min-width: 1024px)").matches
				? 112
				: 80;
			const atPageEnd =
				window.innerHeight + window.scrollY >=
				document.documentElement.scrollHeight - 1;
			const hasVisibleDormAnchor = Array.from(
				document.querySelectorAll("[data-dorm-anchor]"),
			).some((anchor) => {
				const { top, bottom } = anchor.getBoundingClientRect();
				return bottom > 0 && top < window.innerHeight;
			});
			let activeHeading = atPageEnd ? headings.at(-1)! : headings[0];

			if (!atPageEnd) {
				for (const heading of headings) {
					if (heading.getBoundingClientRect().top > readingLine) break;
					activeHeading = heading;
				}
			}

			const activeSlug = activeHeading.id;

			tocElements.forEach((tocElement) => {
				setActiveLink(tocElement, hasVisibleDormAnchor ? undefined : activeSlug);
			});
		}

		tocElements.forEach((tocElement) => {
			const links = tocElement.querySelectorAll(
				"[data-toc-link]:not([data-dorm-link])",
			);

			links.forEach((link) => {
				link.addEventListener("click", () => {
					const slug = link.getAttribute("data-slug");
					if (slug) setActiveLink(tocElement, slug);
				});
			});
		});

		window.addEventListener("scroll", scheduleActiveLinkUpdate, { passive: true });
		window.addEventListener("resize", scheduleActiveLinkUpdate);
		updateActiveLinks();

		cleanupTOC = () => {
			if (animationFrame !== null) cancelAnimationFrame(animationFrame);
			window.removeEventListener("scroll", scheduleActiveLinkUpdate);
			window.removeEventListener("resize", scheduleActiveLinkUpdate);
		};
	}

	// Re-initialize after Astro page transitions
	function initDormTOC() {
		const dorms = (window as any).__dorms__;
		if (!dorms?.length) return;

		const allTocs = document.querySelectorAll("[data-toc] ul");

		allTocs.forEach((toc: Element) => {
			toc.querySelectorAll("[data-dorm-link]").forEach((el) =>
				el.remove(),
			);

			dorms.forEach((dorm: any) => {
				const id = dorm.name.replace(/\s+/g, "-");
				const li = document.createElement("li");
				const a = document.createElement("a");
				a.href = `#${id}`;
				a.setAttribute("data-toc-link", "");
				a.setAttribute("data-slug", id);
				a.setAttribute("data-dorm-link", "");
				a.textContent = dorm.name;
				a.className =
					"block text-ui-text-muted hover:text-ui-text-primary transition-colors border-l border-ui-border -ml-4 py-1 pl-8";
				li.appendChild(a);
				toc.appendChild(li);
			});
		});

		requestAnimationFrame(() => {
			const tocElements = document.querySelectorAll("[data-toc]");
			tocElements.forEach((tocElement) => {
				const links = tocElement.querySelectorAll("[data-toc-link]");
				if (!links.length) return;

				// Track which dorm anchors are currently visible
				const visibleIds = new Set<string>();

				function clearDormLinks() {
					links.forEach((link) => {
						if (link.hasAttribute("data-dorm-link")) {
							link.classList.remove(
								"!text-ui-text-primary",
								"font-medium",
								"!border-l-ui-text-primary",
							);
						}
					});
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							const id = entry.target.getAttribute("id");
							if (!id) return;

							if (entry.isIntersecting) {
								visibleIds.add(id);
							} else {
								visibleIds.delete(id);
							}
						});

						// Clear all dorm links first, then highlight the last visible one
						clearDormLinks();

						if (visibleIds.size > 0) {
							const lastVisibleId = [...visibleIds].at(-1);
							const tocLink = tocElement.querySelector(
								`[data-toc-link][data-slug="${lastVisibleId}"]`,
							);
							if (tocLink) {
								tocLink.classList.add(
									"!text-ui-text-primary",
									"font-medium",
									"!border-l-ui-text-primary",
								);
							}
						}
					},
					{
						rootMargin: "-100px 0px -66%",
						threshold: 0,
					},
				);

				document
					.querySelectorAll("[data-dorm-anchor]")
					.forEach((el) => {
						observer.observe(el);
					});
			});
		});
	}

	initTOC();
	initDormTOC();

	window.addEventListener("dorms-ready", initDormTOC);
	document.addEventListener("astro:after-swap", initTOC);
	document.addEventListener("astro:after-swap", initDormTOC);
</script>
